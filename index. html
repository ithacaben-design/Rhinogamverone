<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>3D Rhinorigami Sanctuary</title>
    <!-- Import Three.js -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <!-- Sharpie-style handwriting font -->
    <link href="https://fonts.googleapis.com/css2?family=Permanent+Marker&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0; 
            overflow: hidden; 
            background-color: #a88b6a; 
            font-family: 'Permanent Marker', cursive;
            touch-action: none; 
        }
        
        #canvas-container {
            position: absolute;
            top: 0; left: 0; width: 100vw; height: 100vh;
            z-index: 1;
        }

        /* 2D UI Overlay aligned to the Goldilocks camera zoom */
        #ui-layer {
            position: absolute;
            top: 50%; left: 50%;
            /* ScaleY(0.76) matches the 45-degree downward camera pitch */
            transform: translate(-50%, -45.5%) scaleY(0.76) rotate(-11.25deg); 
            width: 145px; height: 145px; 
            z-index: 10;
            pointer-events: none; 
        }

        #note-input {
            width: 100%; height: 100%;
            background: transparent; border: none; outline: none;
            color: rgba(20, 20, 25, 0.25); /* Faint "ghost" ink while typing */
            font-size: 18px; 
            font-family: 'Permanent Marker', cursive;
            text-align: center; 
            
            /* Vertical/Horizontal centering */
            display: flex;
            align-items: center;
            justify-content: center;
            flex-direction: column;
            
            pointer-events: auto; 
            padding: 5px; box-sizing: border-box;
            line-height: 1.2;
            overflow: hidden;
            word-wrap: break-word;
        }

        #note-input:focus {
            color: rgba(20, 20, 25, 0.45);
        }

        #night-overlay {
            position: absolute; top: 0; left: 0; width: 100vw; height: 100vh;
            background: rgba(10, 15, 30, 0.0);
            pointer-events: none;
            z-index: 5;
            transition: background 3s ease-in-out;
        }
        body.sleeping #night-overlay {
            background: rgba(10, 15, 30, 0.6);
        }
    </style>
</head>
<body>

    <div id="canvas-container"></div>
    <div id="night-overlay"></div>
    
    <div id="ui-layer">
        <div id="note-input" contenteditable="true" spellcheck="false">I love you</div>
    </div>

    <script>
        // --- 1. CORE SETUP ---
        const colors = {
            yellow: 0xffff88, // Rhino
            blue: 0xa0d8ef,   // Turtle
            pink: 0xfbcce7    // Crane
        };
        const sequence = [colors.yellow, colors.blue, colors.pink];
        let colorIndex = 0;
        
        let scene, camera, renderer;
        let padGroup, topSheetMesh;
        const creatures = [];
        let sleepTimer, isSleeping = false, isWriting = false;
        
        let topSheetCanvas, topSheetCtx, topSheetTexture;
        const clock = new THREE.Clock();

        // --- 2. AUDIO ENGINE (SCRIBBLING & FOLDING) ---
        let audioCtx;
        function initAudio() {
            if (!audioCtx) audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            if (audioCtx.state === 'suspended') audioCtx.resume();
        }

        function playSoftScribble() {
            if (!audioCtx) return;
            const dur = 0.08 + Math.random() * 0.05; 
            const bufferSize = audioCtx.sampleRate * dur;
            const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
            const data = buffer.getChannelData(0);
            for (let i = 0; i < bufferSize; i++) data[i] = Math.random() * 2 - 1; 
            
            const noise = audioCtx.createBufferSource();
            noise.buffer = buffer;
            
            const filter = audioCtx.createBiquadFilter();
            filter.type = 'lowpass';
            filter.frequency.value = 500 + Math.random() * 400; 
            
            const gain = audioCtx.createGain();
            gain.gain.setValueAtTime(0, audioCtx.currentTime); 
            gain.gain.linearRampToValueAtTime(0.04, audioCtx.currentTime + 0.02); 
            gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + dur);
            
            noise.connect(filter).connect(gain).connect(audioCtx.destination);
            noise.start();
        }

        function playFold() {
            if (!audioCtx) return;
            const noise = audioCtx.createBufferSource();
            const dur = 0.2;
            const bufferSize = audioCtx.sampleRate * dur;
            const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);
            const data = buffer.getChannelData(0);
            for (let i = 0; i < bufferSize; i++) data[i] = Math.random() * 2 - 1;
            noise.buffer = buffer;

            const filter = audioCtx.createBiquadFilter();
            filter.type = 'bandpass';
            filter.frequency.setValueAtTime(600, audioCtx.currentTime);
            
            const gain = audioCtx.createGain();
            gain.gain.setValueAtTime(0.15, audioCtx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + dur); 
            
            noise.connect(filter).connect(gain).connect(audioCtx.destination);
            noise.start();
        }

        // --- 3. INITIALIZATION ---
        window.onload = function() {
            document.fonts.ready.then(() => {
                init3D();
                setupInteractions();
                resetSleepTimer();
                animate();
            });
        };

        function init3D() {
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0xa88b6a); 
            scene.fog = new THREE.Fog(0xa88b6a, 100, 300);

            camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 1, 1000);
            // RELAXED ZOOM POSITION
            camera.position.set(0, 110, 130); 
            camera.lookAt(0, 0, 0);

            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.shadowMap.enabled = true;
            renderer.shadowMap.type = THREE.PCFSoftShadowMap;
            document.getElementById('canvas-container').appendChild(renderer.domElement);

            const ambient = new THREE.AmbientLight(0xffffff, 0.6);
            scene.add(ambient);

            const dirLight = new THREE.DirectionalLight(0xffffff, 0.6);
            dirLight.position.set(50, 100, 30);
            dirLight.castShadow = true;
            dirLight.shadow.mapSize.set(1024, 1024);
            scene.add(dirLight);

            // Wood Table
            const desk = new THREE.Mesh(
                new THREE.PlaneGeometry(1000, 1000),
                new THREE.MeshStandardMaterial({ color: 0x8b5a2b, roughness: 0.9 })
            );
            desk.rotation.x = -Math.PI / 2;
            desk.receiveShadow = true;
            scene.add(desk);

            // Post-it Stack
            padGroup = new THREE.Group();
            const padBase = createOutlinedMesh(
                new THREE.BoxGeometry(40, 6, 40),
                new THREE.MeshStandardMaterial({ color: 0xddddcc })
            );
            padBase.position.y = 3;
            padGroup.add(padBase);

            topSheetMesh = createOutlinedMesh(
                new THREE.BoxGeometry(40, 1, 40),
                new THREE.MeshStandardMaterial()
            );
            topSheetMesh.position.y = 6.5;
            padGroup.add(topSheetMesh);

            initDynamicPad(); 

            padGroup.rotation.y = Math.PI / 16; 
            scene.add(padGroup);

            window.addEventListener('resize', () => {
                camera.aspect = window.innerWidth / window.innerHeight;
                camera.updateProjectionMatrix();
                renderer.setSize(window.innerWidth, window.innerHeight);
            });
        }

        // --- 4. TEXTURE & RENDERING HELPERS ---
        function createOutlinedMesh(geometry, material) {
            const mesh = new THREE.Mesh(geometry, material);
            mesh.castShadow = true; mesh.receiveShadow = true;
            const line = new THREE.LineSegments(
                new THREE.EdgesGeometry(geometry),
                new THREE.LineBasicMaterial({ color: 0x000000, linewidth: 2 })
            );
            mesh.add(line);
            return mesh;
        }

        function drawCenteredText(ctx, colorHex, text) {
            ctx.fillStyle = '#' + new THREE.Color(colorHex).getHexString();
            ctx.fillRect(0, 0, 512, 512);
            if (!text || text.trim() === '') return;

            ctx.fillStyle = 'rgba(20, 20, 25, 0.9)';
            ctx.font = '48px "Permanent Marker", cursive';
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            
            ctx.save();
            ctx.translate(256, 256);

            const words = text.split(' ');
            let lines = [], currentLine = '';
            words.forEach(word => {
                if (currentLine.length + word.length > 12) {
                    lines.push(currentLine.trim());
                    currentLine = word + ' ';
                } else currentLine += word + ' ';
            });
            if (currentLine) lines.push(currentLine.trim());
            
            let h = 55, startY = -((lines.length - 1) * h) / 2;
            lines.forEach((l, i) => ctx.fillText(l, 0, startY + (i * h)));
            
            // Folds Stamps
            ctx.font = '24px "Permanent Marker", cursive';
            ctx.rotate(Math.PI / 4);
            ctx.fillText(text, -160, -160);
            ctx.fillText(text, 160, 160);
            ctx.restore();
        }

        function initDynamicPad() {
            topSheetCanvas = document.createElement('canvas');
            topSheetCanvas.width = topSheetCanvas.height = 512;
            topSheetCtx = topSheetCanvas.getContext('2d');
            topSheetTexture = new THREE.CanvasTexture(topSheetCanvas);
            updatePadTexture(sequence[colorIndex], '');
            topSheetMesh.material = new THREE.MeshStandardMaterial({ 
                map: topSheetTexture, color: 0xffffff, roughness: 0.8 
            });
        }

        function updatePadTexture(color, text) {
            drawCenteredText(topSheetCtx, color, text);
            topSheetTexture.needsUpdate = true;
        }

        // --- 5. CREATURE GENERATION ---
        function createCreature(type, color, text) {
            const group = new THREE.Group();
            const mat = new THREE.MeshStandardMaterial({ 
                map: new THREE.CanvasTexture(document.createElement('canvas')),
                color: 0xffffff, roughness: 0.8 
            });
            mat.map.image.width = mat.map.image.height = 512;
            drawCenteredText(mat.map.image.getContext('2d'), color, text);
            mat.map.needsUpdate = true;

            let data;
            if (type === 'rhino') {
                const body = createOutlinedMesh(new THREE.BoxGeometry(10, 8, 14), mat);
                body.position.y = 6; group.add(body);
                const head = createOutlinedMesh(new THREE.ConeGeometry(4, 8, 4), mat);
                head.rotation.x = -Math.PI/2; head.position.set(0, 6, 10); group.add(head);
                const horn = createOutlinedMesh(new THREE.ConeGeometry(1, 4, 4), mat);
                horn.rotation.x = Math.PI/4; horn.position.set(0, 8, 13); group.add(horn);
                const legGeo = new THREE.BoxGeometry(2, 4, 3);
                [[-3, 2, 5], [3, 2, 5], [-3, 2, -5], [3, 2, -5]].forEach(p => {
                    const l = createOutlinedMesh(legGeo, mat); l.position.set(...p); group.add(l);
                });
                data = { group, type: 'rhino', speed: 18, hitbox: 12 };
            } else if (type === 'turtle') {
                const shell = createOutlinedMesh(new THREE.CylinderGeometry(8, 8, 3, 6), mat);
                shell.position.y = 4; group.add(shell);
                const head = createOutlinedMesh(new THREE.BoxGeometry(3, 3, 4), mat);
                head.position.set(0, 4, 9); group.add(head);
                const flipGeo = new THREE.ConeGeometry(2, 7, 3); flipGeo.rotateX(Math.PI/2);
                [[-6, 2, 5, 0.8], [6, 2, 5, -0.8], [-5, 2, -5, 2.1], [5, 2, -5, -2.1]].forEach(p => {
                    const f = createOutlinedMesh(flipGeo, mat); f.position.set(p[0], p[1], p[2]); f.rotation.y = p[3]; group.add(f);
                });
                data = { group, type: 'turtle', speed: 10, hitbox: 10 };
            } else {
                const body = createOutlinedMesh(new THREE.TetrahedronGeometry(4), mat);
                body.position.y = 8; group.add(body);
                const neck = createOutlinedMesh(new THREE.ConeGeometry(1, 12, 3), mat);
                neck.rotation.x = -1; neck.position.set(0, 12, 6); group.add(neck);
                const tail = createOutlinedMesh(new THREE.ConeGeometry(1, 10, 3), mat);
                tail.rotation.x = 1; tail.position.set(0, 10, -5); group.add(tail);
                const wL = new THREE.Group(), wR = new THREE.Group();
                const wGeo = new THREE.ConeGeometry(5, 14, 3); wGeo.rotateZ(Math.PI/2);
                const wlM = createOutlinedMesh(wGeo, mat); wlM.position.x = 7; wL.add(wlM); wL.position.y = 8;
                const wrM = createOutlinedMesh(wGeo, mat); wrM.position.x = -7; wR.add(wrM); wR.position.y = 8;
                group.add(wL, wR);
                data = { group, type: 'crane', speed: 28, hitbox: 8, wings: [wL, wR] };
            }
            return data;
        }

        // --- 6. INTERACTIONS ---
        function setupInteractions() {
            const input = document.getElementById('note-input');
            let firstNote = true, lastTap = 0;

            const trigger = (e) => {
                if (e) e.preventDefault();
                initAudio();
                let text = input.innerText.trim();
                if (firstNote) { text = "I love you"; firstNote = false; }
                if (text !== '' && !isWriting) {
                    input.innerText = ''; input.contentEditable = "false";
                    isWriting = true;
                    let char = 0, scribbleInterval = setInterval(playSoftScribble, 220);
                    const typeWriter = () => {
                        char++;
                        updatePadTexture(sequence[colorIndex], text.substring(0, char));
                        if (char < text.length) setTimeout(typeWriter, 70 + Math.random() * 80);
                        else {
                            clearInterval(scribbleInterval);
                            setTimeout(() => {
                                let types = ['rhino', 'turtle', 'crane'];
                                let cData = createCreature(types[colorIndex % 3], sequence[colorIndex], text);
                                cData.group.position.set(0, 8, 0); cData.group.scale.setScalar(0.01);
                                cData.angle = Math.random() * Math.PI * 2; cData.state = 'spawning'; cData.scale = 0;
                                scene.add(cData.group); creatures.push(cData);
                                playFold(); setTimeout(playFold, 150);
                                colorIndex = (colorIndex + 1) % sequence.length;
                                updatePadTexture(sequence[colorIndex], '');
                                isWriting = false; input.contentEditable = "true"; input.focus();
                            }, 500);
                        }
                    };
                    typeWriter();
                }
            };

            input.addEventListener('keydown', e => { if (e.key === 'Enter') trigger(e); });
            input.addEventListener('touchend', e => {
                let now = Date.now();
                if (now - lastTap < 400 && now - lastTap > 0) trigger(e);
                lastTap = now;
            });
            input.addEventListener('dblclick', trigger);
            window.addEventListener('mousedown', resetSleepTimer);
            window.addEventListener('touchstart', resetSleepTimer);
        }

        function resetSleepTimer() {
            clearTimeout(sleepTimer);
            if (isSleeping) { isSleeping = false; document.body.classList.remove('sleeping'); creatures.forEach(c => c.state = 'moving'); }
            sleepTimer = setTimeout(() => {
                isSleeping = true; document.body.classList.add('sleeping');
                creatures.forEach(c => { c.state = 'sleeping'; c.targetX = -90 + Math.random()*40; c.targetZ = -90 + Math.random()*40; });
            }, 55000);
        }

        // --- 7. ANIMATION ---
        function animate() {
            requestAnimationFrame(animate);
            let delta = clock.getDelta(), time = clock.getElapsedTime();
            creatures.forEach(c => {
                if (c.state === 'spawning') {
                    c.scale += delta * 2;
                    if (c.scale >= 1) { c.scale = 1; c.state = 'moving'; }
                    c.group.scale.setScalar(c.scale);
                }
                if (c.state === 'moving' || c.state === 'sleeping') {
                    let spd = c.speed * delta, ang = c.angle;
                    if (c.state === 'sleeping') {
                        let dx = c.targetX - c.group.position.x, dz = c.targetZ - c.group.position.z;
                        ang = Math.atan2(dx, dz);
                        if (Math.hypot(dx, dz) < 2) spd = 0; else spd *= 0.5;
                    }
                    if (spd > 0) {
                        let nx = c.group.position.x + Math.sin(ang) * spd, nz = c.group.position.z + Math.cos(ang) * spd;
                        const bx = 120, bz = 100;
                        if (nx < -bx || nx > bx) { c.angle = -c.angle; }
                        if (nz < -bz || nz > bz) { c.angle = Math.PI - c.angle; }
                        const pr = 25, dist = Math.hypot(nx, nz);
                        if (dist < pr + c.hitbox && dist > pr * 0.5) {
                            let nAng = Math.atan2(nx, nz);
                            c.angle = (2 * nAng) - ang - Math.PI + (Math.random()-0.5);
                            nx = Math.sin(nAng) * (pr + c.hitbox); nz = Math.cos(nAng) * (pr + c.hitbox);
                        }
                        c.group.position.set(nx, c.group.position.y, nz);
                        c.group.rotation.y = ang;
                    }
                    // Anim Cycles
                    if (c.type === 'rhino' && spd > 0) { c.group.rotation.z = Math.sin(time*15)*0.1; c.group.position.y = 8 + Math.abs(Math.sin(time*15))*1.5; }
                    else if (c.type === 'turtle') { c.group.position.y = 8 + Math.sin(time*3+c.group.id)*1; }
                    else if (c.type === 'crane') {
                        c.group.position.y = 15 + Math.sin(time*5)*3;
                        if (spd > 0) { c.wings[0].rotation.z = -0.5 + Math.sin(time*20)*0.5; c.wings[1].rotation.z = 0.5 - Math.sin(time*20)*0.5; }
                    }
                }
            });
            renderer.render(scene, camera);
        }
    </script>
</body>
</html>

